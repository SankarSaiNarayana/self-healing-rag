# ---- LLM (OpenAI-compatible chat/completions) ----
# This repo uses env names OPENAI_* even for non-OpenAI hosts (Groq, Ollama, etc.).
#
# --- Groq (free tier / fast) — recommended for demos ---
# Create a key: https://console.groq.com/keys  → paste it below as OPENAI_API_KEY (starts with gsk_).
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
# See https://console.groq.com/docs/models for IDs; examples:
OPENAI_MODEL=llama-3.3-70b-versatile
#
# --- OpenAI instead ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
#
# --- Ollama (local) ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.2

# ---- Storage ----
CHROMA_DIR=.chroma

# Vector DB backend: "chroma" (default) or "qdrant"
VECTOR_DB=chroma
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=rag__

# ---- Retrieval tuning ----
TOP_K=8
BM25_K=12
HYBRID_ALPHA=0.55
MIN_RETRIEVAL_SCORE=0.25

# ---- Self-healing ----
MAX_RETRIEVAL_RETRIES=2
MAX_VERIFICATION_RETRIES=2

# ---- API hardening (optional) ----
# API_KEY=
# RATE_LIMIT=120/minute
# UPLOAD_RATE_LIMIT=20/minute
# UPLOAD_MAX_FILES=12
# UPLOAD_MAX_BYTES_PER_FILE=12000000
# UPLOAD_MAX_TOTAL_BYTES=48000000
# CORS_ORIGINS=*
# HEALTH_CHECK_LLM=false

